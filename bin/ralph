#!/usr/bin/env bash
# Universal Ralph Wiggum - AI agent team orchestrator
# Works with Claude Code, Cursor, Copilot, and any CLI-based AI tool.

set -euo pipefail

# Resolve RALPH_ROOT: the directory containing bin/, lib/, adapters/, etc.
# Supports: direct execution, symlinks (any depth), RALPH_ROOT env override.
if [[ -n "${RALPH_ROOT:-}" ]] && [[ -d "${RALPH_ROOT}/lib" ]]; then
  : # RALPH_ROOT already set by the user, use it
else
  SCRIPT_PATH="$0"
  # Follow symlinks to the real file (handles chains of any depth)
  while [[ -L "$SCRIPT_PATH" ]]; do
    local_dir="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
    SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
    # Resolve relative symlink targets
    if [[ "$SCRIPT_PATH" != /* ]]; then
      SCRIPT_PATH="${local_dir}/${SCRIPT_PATH}"
    fi
  done
  RALPH_ROOT="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"

  if [[ ! -d "${RALPH_ROOT}/lib" ]]; then
    echo "ERROR: Cannot find Ralph's lib/ directory." >&2
    echo "Expected at: ${RALPH_ROOT}/lib" >&2
    echo "" >&2
    echo "If you installed Ralph to a custom location, set RALPH_ROOT:" >&2
    echo "  export RALPH_ROOT=/path/to/ralph-wiggum" >&2
    exit 1
  fi
fi
source "${RALPH_ROOT}/lib/utils.sh"

print_banner() {
  cat << 'BANNER'
  ╔══════════════════════════════════════════════╗
  ║  Ralph Wiggum - Universal AI Agent Teams     ║
  ║  "I'm helping!"                              ║
  ╚══════════════════════════════════════════════╝
BANNER
}

usage() {
  cat << EOF
Usage: ralph <command> [options]

Commands:
  init        Set up Ralph (interactive wizard, creates ralph.config.json)
  start       Start a Ralph agent team on a task
  scan        Find git repos on your system, pick one, and start Ralph
  sessions    List sessions, view status, and browse logs
  cancel      Cancel all running agents and clean up
  plan        Run planning mode only (generate fix_plan.md)
  agent       Switch AI CLI tool and/or model
  templates   List or edit prompt templates
  settings    Open ralph.config.json in your editor
  prune       Wipe all state (sessions, worktrees, logs) back to factory

Options:
  -c, --config <file>    Config file (default: ralph.config.json)
  -r, --repo [path]      Target repo for this session (interactive scanner if no path given)
  --cli [tool]           AI tool for this session only (picker if no tool given)
  --model <name>         Model for this session only (e.g. sonnet, opus, gpt-4.1)
  -t, --tool <name>      AI tool: claude-code, cursor, copilot, generic (updates config)
  -p, --prompt <text|file> Prompt: inline text OR path to a .md file
  -n, --implementers <n> Number of implementer agents (default: 3)
  -R, --reviewers <n>    Number of reviewer agents (default: 2)
  -m, --max-iterations   Max retry attempts (default: 3)
  --completion-promise    Phrase that signals task completion
  --allow-all             Skip all permission prompts in the AI tool
  -h, --help              Show this help

The -p flag accepts either a file path or inline text. If the value
is an existing file, it's used as-is. Otherwise it's treated as the
prompt text directly. If -p is omitted, Ralph opens your \$EDITOR
so you can write a formatted prompt (markdown, lists, etc.).

Examples:
  # First time: interactive setup wizard
  ralph init

  # Start with an inline prompt
  ralph start -p "Build a REST API for todos with tests"

  # Let Ralph ask you for the prompt
  ralph start

  # Scan filesystem for repos, pick one interactively
  ralph scan

  # Edit your config
  ralph settings

  # View sessions, status, and logs
  ralph sessions
  ralph sessions --session <id>

  # Cancel running agents
  ralph cancel

  # Wipe all state (or a single session)
  ralph prune
  ralph prune --session <id>
EOF
}

# Parse global arguments and dispatch to subcommands
main() {
  if [[ $# -eq 0 ]]; then
    print_banner
    usage
    exit 0
  fi

  local command="$1"
  shift

  local config_file="${RALPH_ROOT}/ralph.config.json"
  local config_overrides=()

  # Parse global flags that appear before subcommand args
  local args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -c|--config)
        config_file="$2"; shift 2 ;;
      -r|--repo)
        if [[ -n "${2:-}" && "${2:0:1}" != "-" ]]; then
          config_overrides+=("session_target_repo=$2"); shift 2
        else
          config_overrides+=("session_target_repo=__SCAN__"); shift
        fi
        ;;
      -t|--tool)
        config_overrides+=("ai_tool=$2"); shift 2 ;;
      --cli)
        if [[ -n "${2:-}" && "${2:0:1}" != "-" ]]; then
          config_overrides+=("session_cli=$2"); shift 2
        else
          config_overrides+=("session_cli=__PICK__"); shift
        fi
        ;;
      --model)
        if [[ -n "${2:-}" && "${2:0:1}" != "-" ]]; then
          config_overrides+=("session_model=$2"); shift 2
        else
          config_overrides+=("session_model=__PICK__"); shift
        fi
        ;;
      -p|--prompt)
        config_overrides+=("prompt_input=$2"); shift 2 ;;
      -n|--implementers)
        config_overrides+=("team.implementers=$2"); shift 2 ;;
      -R|--reviewers)
        config_overrides+=("team.reviewers=$2"); shift 2 ;;
      -m|--max-iterations)
        config_overrides+=("loop.max_iterations=$2"); shift 2 ;;
      --completion-promise)
        config_overrides+=("loop.completion_promise=$2"); shift 2 ;;
      --claude-teams|--agent-teams)
        shift ;;
      --allow-all)
        config_overrides+=("allow_all=true"); shift ;;
      -h|--help)
        usage; exit 0 ;;
      *)
        args+=("$1"); shift ;;
    esac
  done

  # These commands don't require an existing config
  case "$command" in
    init)
      cmd_init "${args[@]:-}"
      return ;;
    settings|config)
      cmd_settings "$config_file"
      return ;;
    sessions|logs|status)
      cmd_sessions "${args[@]:-}"
      return ;;
    templates)
      cmd_templates "${args[@]:-}"
      return ;;
    prune)
      cmd_prune "${args[@]:-}"
      return ;;
    help|--help|-h)
      usage
      return ;;
  esac

  # All other commands need a config — prompt to run init if missing
  if [[ ! -f "$config_file" ]]; then
    ralph_log ERROR "No ralph.config.json found."
    ralph_log INFO "Run 'ralph init' first to set up your configuration."
    exit 1
  fi

  # Apply config overrides to a temp config
  local effective_config="$config_file"
  if [[ ${#config_overrides[@]} -gt 0 ]]; then
    effective_config="${RALPH_ROOT}/state/.ralph-config-effective.json"
    mkdir -p "$(dirname "$effective_config")"
    cp "$config_file" "$effective_config"
    
    for override in "${config_overrides[@]}"; do
      local key="${override%%=*}"
      local value="${override#*=}"
      local jq_path=".${key}"
      if [[ "$value" == "true" ]] || [[ "$value" == "false" ]] || [[ "$value" =~ ^[0-9]+$ ]]; then
        jq "${jq_path} = ${value}" "$effective_config" > "${effective_config}.tmp"
      else
        jq --arg v "$value" "${jq_path} = \$v" "$effective_config" > "${effective_config}.tmp"
      fi
      mv "${effective_config}.tmp" "$effective_config"
    done
  fi

  case "$command" in
    start)
      cmd_start "$effective_config" "${args[@]:-}"
      ;;
    scan)
      cmd_scan "$effective_config" "${args[@]:-}"
      ;;
    cancel)
      cmd_cancel "$effective_config"
      ;;
    plan)
      cmd_plan "$effective_config" "${args[@]:-}"
      ;;
    agent)
      cmd_agent "$config_file" "${args[@]:-}"
      ;;
    *)
      ralph_log ERROR "Unknown command: $command"
      usage
      exit 1
      ;;
  esac
}

# Scan filesystem for git repos and let user pick one interactively.
# Prints the selected absolute repo path to stdout.
# Returns 1 if no repos found or user cancels.
scan_for_repo() {
  local scan_root="${1:-}"

  local -a search_dirs=()
  if [[ -n "$scan_root" ]]; then
    if [[ ! -d "$scan_root" ]]; then
      ralph_die "Directory not found: $scan_root"
    fi
    search_dirs+=("$scan_root")
  else
    for candidate in "$HOME/projects" "$HOME/repos" "$HOME/src" "$HOME/dev" \
                     "$HOME/code" "$HOME/workspace" "$HOME/github" \
                     "$HOME/Documents/projects" "$HOME/Documents/code" \
                     "$HOME/Developer" "$HOME"; do
      [[ -d "$candidate" ]] && search_dirs+=("$candidate")
    done
    if [[ ${#search_dirs[@]} -eq 0 ]]; then
      search_dirs+=("$HOME")
    fi
  fi

  ralph_log INFO "Scanning for git repositories..." >&2
  ralph_log INFO "Search paths: ${search_dirs[*]}" >&2
  echo "" >&2

  local -a repos=()
  local repo_count=0

  for search_dir in "${search_dirs[@]}"; do
    while IFS= read -r git_dir; do
      local repo_path
      repo_path=$(dirname "$git_dir")
      [[ "$repo_path" == "$RALPH_ROOT" ]] && continue
      [[ -f "${repo_path}/HEAD" ]] && [[ ! -d "${repo_path}/.git" ]] && continue
      repos+=("$repo_path")
      repo_count=$((repo_count + 1))
    done < <(find "$search_dir" -maxdepth 4 -name ".git" -type d \
              ! -path "*/node_modules/*" \
              ! -path "*/.cache/*" \
              ! -path "*/Library/*" \
              ! -path "*/.Trash/*" \
              ! -path "*/.local/*" \
              2>/dev/null | sort)
  done

  # Deduplicate using sort -u (bash 3.2 compatible, no associative arrays)
  local -a unique_repos=()
  local seen_list=""
  for r in "${repos[@]}"; do
    local abs_r
    abs_r=$(cd "$r" 2>/dev/null && pwd) || continue
    case "$seen_list" in
      *"|${abs_r}|"*) ;;
      *)
        seen_list="${seen_list}|${abs_r}|"
        unique_repos+=("$abs_r")
        ;;
    esac
  done
  repos=("${unique_repos[@]}")
  repo_count=${#repos[@]}

  if [[ $repo_count -eq 0 ]]; then
    ralph_log WARN "No git repositories found." >&2
    return 1
  fi

  echo "  Found $repo_count git repositories:" >&2
  echo "" >&2

  local idx=1
  for repo_path in "${repos[@]}"; do
    local branch="" last_commit="" lang_hint=""
    branch=$(git -C "$repo_path" branch --show-current 2>/dev/null || echo "???")
    last_commit=$(git -C "$repo_path" log -1 --format='%cr' 2>/dev/null || echo "unknown")

    if [[ -f "${repo_path}/package.json" ]]; then lang_hint="JS/TS"
    elif [[ -f "${repo_path}/Cargo.toml" ]]; then lang_hint="Rust"
    elif [[ -f "${repo_path}/go.mod" ]]; then lang_hint="Go"
    elif [[ -f "${repo_path}/requirements.txt" ]] || [[ -f "${repo_path}/pyproject.toml" ]]; then lang_hint="Python"
    elif [[ -f "${repo_path}/Gemfile" ]]; then lang_hint="Ruby"
    elif [[ -f "${repo_path}/pom.xml" ]] || [[ -f "${repo_path}/build.gradle" ]]; then lang_hint="Java"
    elif [[ -f "${repo_path}/mix.exs" ]]; then lang_hint="Elixir"
    else lang_hint=""
    fi

    local display_path="${repo_path/#$HOME/~}"
    printf "  %3d) %-50s [%s] %s  (%s)\n" \
      "$idx" "$display_path" "$branch" "${lang_hint:+[$lang_hint]}" "$last_commit" >&2
    idx=$((idx + 1))
  done

  echo "" >&2

  local selection
  while true; do
    printf "  Select a repository [1-%d] (or 'q' to quit): " "$repo_count" >&2
    read -r selection < /dev/tty

    if [[ "$selection" == "q" ]] || [[ "$selection" == "Q" ]]; then
      return 1
    fi

    if [[ "$selection" =~ ^[0-9]+$ ]] && [[ "$selection" -ge 1 ]] && [[ "$selection" -le "$repo_count" ]]; then
      echo "${repos[$((selection - 1))]}"
      return 0
    fi

    echo "  Invalid selection. Enter a number between 1 and $repo_count." >&2
  done
}

cmd_scan() {
  local config="$1"; shift
  local scan_root="${1:-}"

  print_banner
  require_jq

  local chosen_repo
  chosen_repo=$(scan_for_repo "$scan_root") || return 1

  ralph_log INFO "Selected: $chosen_repo"
  echo ""
  echo "  1) Start Ralph on this repo now"
  echo "  2) Set it as the target repo and exit"
  echo ""
  printf "  Choice [1]: "
  read -r action

  case "${action:-1}" in
    1)
      local prompt_file=""
      prompt_file=$(resolve_prompt "" "$config") || true

      if [[ -z "$prompt_file" ]]; then
        ralph_die "No prompt provided. Use -p \"your prompt\" or -p file.md"
      fi
      local scan_config="${RALPH_ROOT}/state/.ralph-config-scan.json"
      mkdir -p "$(dirname "$scan_config")"
      jq --arg repo "$chosen_repo" --arg pf "$prompt_file" \
        '.default_target_repo = $repo | .prompt_file = $pf' "$config" > "$scan_config"
      cmd_start "$scan_config" "$prompt_file"
      ;;
    2)
      jq --arg repo "$chosen_repo" '.default_target_repo = $repo' "$config" > "${config}.tmp"
      mv "${config}.tmp" "$config"
      ralph_log INFO "Default target repo set to: $chosen_repo"
      ralph_log INFO "Next: ralph start -p \"your prompt\""
      ;;
    *)
      echo "  Invalid choice."
      return 1
      ;;
  esac
}

# Resolve prompt input into a file path.
# Accepts: existing file, inline text, or prompts interactively.
# Returns the path via stdout.
resolve_prompt() {
  local input="$1"
  local config="$2"

  # 1. Try -p value
  if [[ -n "$input" ]]; then
    # If it's an existing file, use it directly
    if [[ -f "$input" ]]; then
      echo "$input"
      return 0
    fi
    local tmpfile="${RALPH_ROOT}/state/prompts/.ralph-prompt-$(date +%s).md"
    mkdir -p "${RALPH_ROOT}/state/prompts"
    printf '%s\n' "$input" > "$tmpfile"
    echo "$tmpfile"
    return 0
  fi

  # 2. Try config file fields: prompt_input, prompt_file, prompt_text
  if [[ -n "$config" ]] && [[ -f "$config" ]]; then
    local cfg_input cfg_file cfg_text
    # prompt_input is set by the -p flag override
    cfg_input=$(config_get "$config" '.prompt_input' '')
    if [[ -n "$cfg_input" ]]; then
      if [[ -f "$cfg_input" ]]; then
        echo "$cfg_input"
        return 0
      fi
      local tmpfile="${RALPH_ROOT}/state/prompts/.ralph-prompt-$(date +%s).md"
      mkdir -p "${RALPH_ROOT}/state/prompts"
      printf '%s\n' "$cfg_input" > "$tmpfile"
      echo "$tmpfile"
      return 0
    fi
    cfg_file=$(config_get "$config" '.prompt_file' '')
    if [[ -n "$cfg_file" ]] && [[ -f "$cfg_file" ]]; then
      echo "$cfg_file"
      return 0
    fi
    cfg_text=$(config_get "$config" '.prompt_text' '')
    if [[ -n "$cfg_text" ]]; then
      local tmpfile="${RALPH_ROOT}/state/prompts/.ralph-prompt-$(date +%s).md"
      mkdir -p "${RALPH_ROOT}/state/prompts"
      printf '%s\n' "$cfg_text" > "$tmpfile"
      echo "$tmpfile"
      return 0
    fi
  fi

  # 3. Interactive: open $EDITOR for a rich editing experience
  if [[ -t 0 ]]; then
    local tmpfile="${RALPH_ROOT}/state/prompts/.ralph-prompt-$(date +%s).md"
    mkdir -p "${RALPH_ROOT}/state/prompts"

    local editor="${EDITOR:-${VISUAL:-}}"
    if [[ -z "$editor" ]]; then
      for candidate in nano vim vi; do
        if command -v "$candidate" >/dev/null 2>&1; then
          editor="$candidate"; break
        fi
      done
    fi

    if [[ -n "$editor" ]]; then
      cat > "$tmpfile" << 'PROMPT_TEMPLATE'
# Ralph Wiggum — What should Ralph work on?
#
# Write your prompt below. Use full markdown: lists, headings, code blocks.
# Lines starting with # are comments and will be stripped.
#
# Save and close the editor when done. Leave empty to cancel.

PROMPT_TEMPLATE

      echo "" >&2
      ralph_log INFO "Opening editor ($editor) for your prompt..." >&2
      "$editor" "$tmpfile" < /dev/tty > /dev/tty

      # Strip comment lines and leading/trailing blank lines (BSD sed compatible)
      local cleaned
      cleaned=$(awk '
        !/^#/ {
          line[++n] = $0
          if ($0 ~ /[^[:space:]]/) { last = n; if (!first) first = n }
        }
        END { for (i = first; i <= last; i++) print line[i] }
      ' "$tmpfile")

      if [[ -z "$cleaned" ]]; then
        rm -f "$tmpfile"
        return 1
      fi

      printf '%s\n' "$cleaned" > "$tmpfile"
      echo "$tmpfile"
      return 0
    fi

    # Fallback: no editor available, use simple stdin
    echo "" >&2
    echo "No prompt provided. What should Ralph work on?" >&2
    echo "(Type your prompt, then press Enter. For multiline, end with Ctrl-D)" >&2
    echo "" >&2
    printf "> " >&2
    local user_text
    user_text=$(cat)
    if [[ -z "$user_text" ]]; then
      return 1
    fi
    printf '%s\n' "$user_text" > "$tmpfile"
    echo "$tmpfile"
    return 0
  fi

  return 1
}

cmd_start() {
  local config="$1"; shift
  local prompt_input="${1:-}"

  print_banner
  require_jq

  local prompt_file
  prompt_file=$(resolve_prompt "$prompt_input" "$config") || \
    ralph_die "Prompt required. Use -p \"your prompt\" or -p file.md"

  local target_repo ai_tool

  # Determine target repo: --repo flag > config default
  local session_target_repo
  session_target_repo=$(config_get "$config" '.session_target_repo' '')
  if [[ "$session_target_repo" == "__SCAN__" ]]; then
    session_target_repo=$(scan_for_repo) || ralph_die "No repository selected."
    ralph_log INFO "Selected: $session_target_repo"
  fi

  if [[ -n "$session_target_repo" ]]; then
    target_repo="$session_target_repo"
  else
    target_repo=$(config_get "$config" '.default_target_repo' '')
    # Backward compat: fall back to legacy "target_repo" key
    if [[ -z "$target_repo" ]]; then
      target_repo=$(config_get "$config" '.target_repo' '.')
    fi
  fi

  ai_tool=$(config_get "$config" '.ai_tool' 'claude-code')

  # Per-session overrides via --cli and --model
  local session_cli session_tool_command="" session_model
  session_cli=$(config_get "$config" '.session_cli' '')
  session_model=$(config_get "$config" '.session_model' '')

  if [[ "$session_cli" == "__PICK__" ]]; then
    session_cli=$(_pick_ai_tool "$ai_tool")
    echo ""
  fi

  local model
  model=$(config_get "$config" '.model' 'sonnet')

  if [[ -n "$session_cli" ]]; then
    ai_tool="$session_cli"
    # CLI changed — prompt for model if not explicitly given via --model
    if [[ -z "$session_model" ]]; then
      ralph_log INFO "  CLI switched to: $ai_tool — select a model for this session"
      session_model=$(_pick_model "$ai_tool" "$model")
      echo ""
    fi
  fi

  if [[ "$session_model" == "__PICK__" ]]; then
    session_model=$(_pick_model "$ai_tool" "$model")
    echo ""
  fi

  if [[ -n "$session_model" ]]; then
    model="$session_model"
  fi

  # Prompt for manager model when --cli or --model overrides are active
  local session_mgr_model=""
  if [[ -n "$session_cli" || -n "$session_model" ]]; then
    local current_mgr
    current_mgr=$(config_get "$config" '.manager_model' "$model")
    printf "  Manager model [current: %s, enter = same as worker (%s)]: " "$current_mgr" "$model"
    read -r session_mgr_model </dev/tty
    session_mgr_model="${session_mgr_model:-$model}"
    echo ""
    session_tool_command=$(_build_tool_command "$ai_tool" "$model")
  fi

  # Resolve target repo to absolute path
  if [[ "$target_repo" != /* ]]; then
    target_repo="$(cd "$target_repo" 2>/dev/null && pwd)" || ralph_die "Target repo not found: $target_repo"
  fi

  # Ensure user-editable templates are present
  sync_templates "$RALPH_ROOT"

  # --- Session isolation via worktrees ---
  source "${RALPH_ROOT}/lib/worktree.sh"

  local session_id
  session_id=$(printf '%s-%s-%s' "$(date +%s)" "$$" "$RANDOM" | shasum | cut -c1-8)
  export RALPH_SESSION_ID="$session_id"

  local session_dir="${RALPH_ROOT}/state/sessions/${session_id}"
  mkdir -p "$session_dir"/{logs,prompts}
  export RALPH_SESSION_DIR="$session_dir"

  local original_target_repo="$target_repo"

  local worktree_path
  worktree_path=$(worktree_create "$target_repo" "$session_id")
  target_repo="$worktree_path"
  ralph_log INFO "  Worktree: $worktree_path"
  ralph_log INFO "  Branch: ralph/$session_id"

  if [[ "$ai_tool" == "cursor" ]]; then
    ralph_log INFO "  Opening worktree in a new Cursor window..."
    cursor "$worktree_path" >/dev/null 2>&1 &
    local cursor_wait=8
    ralph_log INFO "  Waiting ${cursor_wait}s for Cursor to initialize..."
    sleep "$cursor_wait"
  fi

  # Write effective config — downstream code reads .target_repo
  local session_config="${session_dir}/.ralph-config-effective.json"
  local _clean='del(.session_target_repo) | del(.session_cli) | del(.session_model)'
  local _mgr_update=""
  if [[ -n "$session_mgr_model" ]]; then
    _mgr_update=' | .manager_model = $mm'
  fi
  if [[ -n "$session_tool_command" ]]; then
    jq --arg repo "$target_repo" --arg tool "$ai_tool" --arg cmd "$session_tool_command" --arg m "$model" --arg mm "$session_mgr_model" \
      ".target_repo = \$repo | .ai_tool = \$tool | .ai_tool_command = \$cmd | .model = \$m${_mgr_update} | ${_clean}" \
      "$config" > "$session_config"
  elif [[ -n "$session_model" ]]; then
    jq --arg repo "$target_repo" --arg m "$model" --arg mm "$session_mgr_model" \
      ".target_repo = \$repo | .model = \$m${_mgr_update} | ${_clean}" \
      "$config" > "$session_config"
  else
    jq --arg repo "$target_repo" ".target_repo = \$repo | ${_clean}" "$config" > "$session_config"
  fi
  config="$session_config"

  # Write session metadata
  jq -n \
    --arg sid "$session_id" \
    --arg orig "$original_target_repo" \
    --arg wt "$target_repo" \
    --arg branch "ralph/$session_id" \
    --arg started "$(date -u '+%Y-%m-%dT%H:%M:%SZ')" \
    --arg prompt "$prompt_file" \
    --arg tool "$ai_tool" \
    '{
      session_id: $sid,
      original_target_repo: $orig,
      worktree_path: $wt,
      branch: $branch,
      started_at: $started,
      prompt_file: $prompt,
      ai_tool: $tool
    }' > "${session_dir}/session.json"

  ralph_log INFO "Starting Ralph Wiggum agent team"
  ralph_log INFO "  Session: $session_id"
  ralph_log INFO "  Target repo: $target_repo"
  ralph_log INFO "  AI tool: $ai_tool"
  ralph_log INFO "  Prompt: $prompt_file"

  ralph_log INFO "Starting interactive agent teams session (works with any AI tool)..."
  ralph_log INFO "  Use 'ralph sessions' to see per-turn progress."
  exec "${RALPH_ROOT}/bin/ralph-interactive.sh" "$config" "$prompt_file"
}

cmd_init() {
  local target_dir="${1:-}"

  print_banner
  require_jq

  local config_file="${RALPH_ROOT}/ralph.config.json"

  if [[ -f "$config_file" ]]; then
    echo ""
    echo "  ralph.config.json already exists."
    printf "  Reconfigure from scratch? [y/N]: "
    read -r yn
    if [[ "$yn" != "y" ]] && [[ "$yn" != "Y" ]]; then
      echo "  Cancelled. Use 'ralph settings' to edit the existing config."
      return 0
    fi
    rm -f "$config_file"
  fi

  echo ""
  echo "  Welcome to Ralph Wiggum setup."
  echo "  This will create your ralph.config.json."
  echo ""

  # --- Step 1: Target repository ---
  if [[ -z "$target_dir" ]]; then
    echo "  Where is your project?"
    echo ""
    echo "    1) Type a path"
    echo "    2) Scan my filesystem for git repos"
    echo "    3) Use current directory ($(pwd))"
    echo ""
    printf "  Choice [1]: "
    read -r repo_choice
    case "${repo_choice:-1}" in
      2)
        target_dir=$(scan_for_repo) || ralph_die "No repository selected."
        ;;
      3)
        target_dir="$(pwd)"
        ;;
      *)
        printf "\n  Repository path: "
        read -r target_dir
        target_dir="${target_dir:-.}"
        ;;
    esac
  fi

  target_dir="${target_dir/#\~/$HOME}"
  if [[ "$target_dir" != /* ]]; then
    target_dir="$(cd "$target_dir" 2>/dev/null && pwd)" || ralph_die "Directory not found: $target_dir"
  fi
  [[ ! -d "$target_dir" ]] && ralph_die "Directory not found: $target_dir"

  echo ""

  # --- Step 2: AI tool ---
  echo "  Which AI tool will you use?"
  echo ""
    echo "    1) claude-code   (best supported, native Agent Teams)"
  echo "    2) cursor         (Cursor CLI — agent)"
  echo "    3) copilot        (GitHub Copilot CLI — copilot)"
  echo "    4) generic        (any CLI tool)"
  echo ""
  printf "  Choice [1]: "
  read -r tool_choice
  local ai_tool
  case "${tool_choice:-1}" in
    1) ai_tool="claude-code" ;;
    2) ai_tool="cursor" ;;
    3) ai_tool="copilot" ;;
    4) ai_tool="generic" ;;
    *) ai_tool="claude-code" ;;
  esac

  echo ""

  # --- Step 3: Model ---
  echo "  Which model?"
  echo ""
  if [[ "$ai_tool" == "claude-code" ]]; then
    echo "    1) sonnet        (Claude Sonnet - fast, affordable)"
    echo "    2) opus          (Claude Opus - smartest, expensive)"
    echo "    3) haiku         (Claude Haiku - fastest, cheapest)"
    echo "    4) gpt-4.1       (OpenAI GPT-4.1)"
    echo "    5) gpt-4.1-mini  (OpenAI GPT-4.1 Mini)"
    echo "    6) o3            (OpenAI o3)"
    echo "    7) gemini-2.5    (Google Gemini 2.5 Pro)"
    echo "    8) Custom        (type your own)"
  else
    echo "    1) sonnet        (Claude Sonnet)"
    echo "    2) opus          (Claude Opus)"
    echo "    3) gpt-4.1       (OpenAI GPT-4.1)"
    echo "    4) gpt-4.1-mini  (OpenAI GPT-4.1 Mini)"
    echo "    5) o3            (OpenAI o3)"
    echo "    6) gemini-2.5    (Google Gemini 2.5 Pro)"
    echo "    7) Custom        (type your own)"
  fi
  echo ""
  printf "  Choice [1]: "
  read -r model_choice
  local model
  if [[ "$ai_tool" == "claude-code" ]]; then
    case "${model_choice:-1}" in
      1) model="sonnet" ;;
      2) model="opus" ;;
      3) model="haiku" ;;
      4) model="gpt-4.1" ;;
      5) model="gpt-4.1-mini" ;;
      6) model="o3" ;;
      7) model="gemini-2.5-pro" ;;
      8)
        printf "\n  Model name: "
        read -r model
        [[ -z "$model" ]] && model="sonnet"
        ;;
      *) model="sonnet" ;;
    esac
  else
    case "${model_choice:-1}" in
      1) model="sonnet" ;;
      2) model="opus" ;;
      3) model="gpt-4.1" ;;
      4) model="gpt-4.1-mini" ;;
      5) model="o3" ;;
      6) model="gemini-2.5-pro" ;;
      7)
        printf "\n  Model name: "
        read -r model
        [[ -z "$model" ]] && model="sonnet"
        ;;
      *) model="sonnet" ;;
    esac
  fi

  # Build ai_tool_command with the selected model
  # Permission-skipping flags are NOT included by default.
  # Use ralph start --allow-all to skip permissions at runtime.
  # Copilot always needs --allow-all (no config-based permission system).
  local ai_tool_command
  case "$ai_tool" in
    claude-code) ai_tool_command="claude --model ${model} -p" ;;
    cursor)      ai_tool_command="agent --model ${model} -p" ;;
    copilot)     ai_tool_command="copilot --allow-all --model ${model} -p" ;;
    generic)     ai_tool_command="" ;;
  esac

  echo ""

  # --- Step 4: Team size ---
  printf "  Number of implementer agents [3]: "
  read -r n_impl
  n_impl="${n_impl:-3}"

  printf "  Number of reviewer agents [2]: "
  read -r n_rev
  n_rev="${n_rev:-2}"

  echo ""

  # --- Step 5: Interactive session settings ---
  printf "  Max conversation turns per attempt [50]: "
  read -r max_turns
  max_turns="${max_turns:-50}"

  printf "  Max retry attempts (outer loop) [3]: "
  read -r max_iter
  max_iter="${max_iter:-3}"

  echo ""

  # --- Step 5b: Manager model ---
  echo "  The manager AI reviews progress and approves plans between turns."
  echo "  A cheaper/faster model is recommended to reduce cost."
  echo ""
  printf "  Manager model [sonnet]: "
  read -r mgr_model
  mgr_model="${mgr_model:-sonnet}"

  echo ""

  # --- Step 6: Allow all permissions ---
  local allow_all="false"
  if [[ "$ai_tool" == "copilot" ]]; then
    allow_all="true"
    echo "  Copilot CLI has no config-based permissions — --allow-all is always on."
  else
    echo "  Skip all permission prompts? (runs AI tools unattended)"
    if [[ "$ai_tool" == "claude-code" ]]; then
      echo "  Adds --dangerously-skip-permissions to claude."
    elif [[ "$ai_tool" == "cursor" ]]; then
      echo "  Adds --force --approve-mcps to agent."
    fi
    echo "  You can also configure permissions via config files instead."
    echo ""
    printf "  Allow all permissions? [y/N]: "
    read -r aa
    if [[ "$aa" == "y" ]] || [[ "$aa" == "Y" ]]; then
      allow_all="true"
    fi
  fi
  echo ""

  # --- Step 8: Custom AI command (for generic tools) ---
  if [[ "$ai_tool" == "generic" ]]; then
    echo "  Enter the command to invoke your AI tool."
    echo "  Ralph will pipe the prompt into this command via stdin."
    echo ""
    printf "  AI command: "
    read -r ai_tool_command
    [[ -z "$ai_tool_command" ]] && ralph_die "AI command is required for generic tools."
    echo ""
  fi

  # --- Generate config ---
  ralph_log INFO "Writing ralph.config.json..."

  cat > "$config_file" << CONFIGEOF
{
  "version": "1.0.0",
  "default_target_repo": $(printf '%s' "$target_dir" | jq -Rs .),
  "prompt_text": "",
  "ai_tool": $(printf '%s' "$ai_tool" | jq -Rs .),
  "ai_tool_command": $(printf '%s' "$ai_tool_command" | jq -Rs .),
  "model": $(printf '%s' "$model" | jq -Rs .),
  "manager_model": $(printf '%s' "$mgr_model" | jq -Rs .),
  "allow_all": ${allow_all},
  "turns": ${max_turns},
  "team": {
    "implementers": ${n_impl},
    "reviewers": ${n_rev}
  },
  "loop": {
    "max_iterations": ${max_iter},
    "completion_promise": "ALL_TASKS_COMPLETE"
  },
  "claude_teams": {
    "teammate_mode": "in-process"
  }
}
CONFIGEOF

  ralph_log INFO "Config saved to: $config_file"
  mkdir -p "${RALPH_ROOT}/state"/{logs,prompts}
  sync_templates "$RALPH_ROOT"

  echo ""
  ralph_log INFO "Done! Ralph is ready."
  echo ""

  # Permission configuration guidance (skip if user already chose allow_all)
  if [[ "$allow_all" == "true" ]]; then
    echo "  Permissions: allow_all is ON — all tools run without prompts."
    echo ""
  else
    case "$ai_tool" in
      claude-code)
        echo "  ┌─ Permissions ──────────────────────────────────────────────┐"
        echo "  │ Ralph respects Claude Code's permission config by default. │"
        echo "  │ For unattended loops, configure permissions:               │"
        echo "  │                                                            │"
        echo "  │   ~/.claude/settings.json:                                 │"
        echo "  │   {                                                        │"
        echo "  │     \"permissions\": {                                       │"
        echo "  │       \"allow\": [\"Bash\", \"Read\", \"Edit\", \"WebFetch\"]         │"
        echo "  │     }                                                      │"
        echo "  │   }                                                        │"
        echo "  │                                                            │"
        echo "  │ Or re-run 'ralph init' and enable allow_all,               │"
        echo "  │ or pass --allow-all at runtime.                            │"
        echo "  │                                                            │"
        echo "  │ Docs: https://code.claude.com/docs/en/permissions          │"
        echo "  └────────────────────────────────────────────────────────────┘"
        echo ""
        ;;
      cursor)
        echo "  ┌─ Permissions ──────────────────────────────────────────────┐"
        echo "  │ Ralph respects Cursor's permission config by default.      │"
        echo "  │ For unattended loops, configure permissions:               │"
        echo "  │                                                            │"
        echo "  │   ~/.cursor/cli-config.json:                               │"
        echo "  │   {                                                        │"
        echo "  │     \"permissions\": {                                       │"
        echo "  │       \"allow\": [                                           │"
        echo "  │         \"Shell(*)\", \"Read(**)\", \"Write(**)\", \"Mcp(*:*)\"    │"
        echo "  │       ]                                                    │"
        echo "  │     }                                                      │"
        echo "  │   }                                                        │"
        echo "  │                                                            │"
        echo "  │ Or re-run 'ralph init' and enable allow_all,               │"
        echo "  │ or pass --allow-all at runtime.                            │"
        echo "  │                                                            │"
        echo "  │ Docs: https://cursor.com/docs/cli/reference/permissions    │"
        echo "  └────────────────────────────────────────────────────────────┘"
        echo ""
      ;;
      copilot)
        echo "  ┌─ Permissions ──────────────────────────────────────────────┐"
        echo "  │ Copilot CLI has no config-file-based permission system.    │"
        echo "  │ --allow-all is included by default for unattended loops.   │"
        echo "  │                                                            │"
        echo "  │ Docs: https://docs.github.com/en/copilot/how-tos/         │"
        echo "  │       copilot-cli/allowing-tools                           │"
        echo "  └────────────────────────────────────────────────────────────┘"
        echo ""
        ;;
    esac
  fi

  echo "  Next steps:"
  echo "    ralph start -p \"Describe what you want built\""
  echo "    ralph settings          # to tweak config"
  echo ""
}

cmd_sessions() {
  local session_filter=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --session) session_filter="$2"; shift 2 ;;
      *) shift ;;
    esac
  done

  require_jq

  local sessions_dir="${RALPH_ROOT}/state/sessions"
  local pager="${PAGER:-less}"
  if ! command -v "$pager" >/dev/null 2>&1; then
    pager="cat"
  fi

  # If a session was specified, go directly to its logs
  if [[ -n "$session_filter" ]]; then
    local sdir="${sessions_dir}/${session_filter}"
    if [[ ! -d "$sdir" ]]; then
      ralph_die "Session not found: $session_filter"
    fi
    _sessions_detail "$sdir" "$pager"
    return
  fi

  # Collect sessions
  local -a sdirs=()
  if [[ -d "$sessions_dir" ]]; then
    for d in "$sessions_dir"/*/; do
      [[ -d "$d" ]] && sdirs+=("$d")
    done
  fi

  if [[ ${#sdirs[@]} -eq 0 ]]; then
    echo ""
    echo "  No sessions found. Run 'ralph start' to begin."
    echo ""
    local legacy_log="${RALPH_ROOT}/state/logs/agent-teams"
    if [[ -d "$legacy_log" ]]; then
      echo "  (Legacy logs found at state/logs/agent-teams/)"
    fi
    return
  fi

  # Build session list with status info
  echo ""
  echo "=== Ralph Sessions ==="
  echo ""

  local idx=1
  local -a sids=()
  for d in "${sdirs[@]}"; do
    local sid
    sid=$(basename "$d")
    sids+=("$sid")
    local meta="${d}session.json"

    local repo branch status_str
    if [[ -f "$meta" ]]; then
      repo=$(jq -r '.original_target_repo // "?"' "$meta" | xargs basename 2>/dev/null || echo "?")
      branch=$(jq -r '.branch // "?"' "$meta")
    else
      repo="?"; branch="?"
    fi

    # Detect if session is active
    status_str=$(_sessions_status "$d" "$meta")

    printf "  %2d) %-8s  %-10s  %-25s  %s\n" "$idx" "$sid" "$status_str" "$repo" "$branch"
    idx=$((idx + 1))
  done
  echo ""

  # If only one session, show its detail automatically
  if [[ ${#sdirs[@]} -eq 1 ]]; then
    _sessions_detail "${sdirs[0]}" "$pager"
    return
  fi

  local count=${#sdirs[@]}
  printf "  Select session [1-%d] (or 'q' to quit): " "$count"
  local sel
  read -r sel </dev/tty

  if [[ "$sel" == "q" || "$sel" == "Q" || -z "$sel" ]]; then
    return
  fi

  if [[ "$sel" =~ ^[0-9]+$ ]] && [[ "$sel" -ge 1 ]] && [[ "$sel" -le "$count" ]]; then
    _sessions_detail "${sdirs[$((sel - 1))]}" "$pager"
  else
    echo "  Invalid selection."
  fi
}

# Print RUNNING/IDLE status for a session directory.
_sessions_status() {
  local sdir="$1"
  local meta="$2"

  if [[ ! -f "$meta" ]]; then
    echo "IDLE"
    return
  fi

  local newest=""
  newest=$(find "$sdir" -type f -newer "$meta" -print 2>/dev/null | head -1)
  if [[ -n "$newest" ]]; then
    local now_epoch mod_epoch age
    now_epoch=$(date +%s)
    if [[ "$(uname)" == "Darwin" ]]; then
      mod_epoch=$(stat -f %m "$newest")
    else
      mod_epoch=$(stat -c %Y "$newest")
    fi
    age=$(( now_epoch - mod_epoch ))
    if [[ $age -lt 120 ]]; then
      echo "RUNNING"
    else
      echo "IDLE"
    fi
  else
    echo "IDLE"
  fi
}

# Show detail for a session, then offer to browse its logs.
_sessions_detail() {
  local sdir="$1"
  local pager="$2"
  local sid
  sid=$(basename "$sdir")
  local meta="${sdir}/session.json"

  echo ""
  echo "--- Session: $sid ---"

  if [[ -f "$meta" ]]; then
    local repo branch started
    repo=$(jq -r '.original_target_repo // "?"' "$meta")
    branch=$(jq -r '.branch // "?"' "$meta")
    started=$(jq -r '.started_at // "?"' "$meta")
    echo "  Repo:     $(basename "$repo")  ($repo)"
    echo "  Branch:   $branch"
    echo "  Started:  $started"
    echo "  Status:   $(_sessions_status "$sdir" "$meta")"
  fi

  # Find latest attempt
  local log_dir="${sdir}/logs/agent-teams"
  local latest_attempt=""

  # Logs live under agent-teams/<session_id>/attempt-N/
  if [[ -d "$log_dir" ]]; then
    for sub in "$log_dir"/*/; do
      [[ -d "$sub" ]] || continue
      for d in "$sub"/attempt-*/; do
        [[ -d "$d" ]] && latest_attempt="$d"
      done
    done
    # Fall back to legacy flat layout
    if [[ -z "$latest_attempt" ]]; then
      for d in "$log_dir"/attempt-*/; do
        [[ -d "$d" ]] && latest_attempt="$d"
      done
    fi
  fi

  if [[ -z "$latest_attempt" ]]; then
    echo "  No attempts yet."
    echo ""
    return
  fi

  local attempt_num
  attempt_num=$(basename "$latest_attempt" | sed 's/attempt-//')
  echo "  Attempt:  $attempt_num"

  local turn_count=0
  local latest_turn=""
  for f in "$latest_attempt"/turn-*.log; do
    [[ -f "$f" ]] || continue
    turn_count=$((turn_count + 1))
    latest_turn="$f"
  done
  echo "  Turns:    $turn_count"

  local verification="${latest_attempt}/verification.log"
  if [[ -f "$verification" ]]; then
    echo ""
    echo "  --- Verification Verdict ---"
    cat "$verification"
  fi

  local latest_mgr=""
  for f in "$latest_attempt"/manager-*.log; do
    [[ -f "$f" ]] && latest_mgr="$f"
  done
  if [[ -n "$latest_mgr" ]]; then
    echo ""
    echo "  --- Last Manager Response ---"
    cat "$latest_mgr"
  fi

  if [[ -n "$latest_turn" ]]; then
    echo ""
    echo "  --- Last Turn Output (last 20 lines) ---"
    tail -20 "$latest_turn"
  fi

  echo ""

  # Offer to browse logs
  local session_logs="${log_dir}/${sid}"
  if [[ -d "$session_logs" ]]; then
    printf "  Browse logs? [Y/n]: "
    local browse
    read -r browse </dev/tty
    if [[ "$browse" != "n" && "$browse" != "N" ]]; then
      while true; do
        _logs_browse_dir "$session_logs" "$pager" || break
      done
    fi
  fi
}

cmd_cancel() {
  local config="$1"

  source "${RALPH_ROOT}/lib/agent-registry.sh"

  init_agent_dir "$RALPH_ROOT"

  ralph_log INFO "Cancelling all Ralph agents..."
  agent_kill_all

  ralph_log INFO "All agents cancelled."
  ralph_log INFO "Run 'ralph sessions' to see session states."
}

_logs_browse_runs() {
  local logs_root="$1"
  local pager="$2"

  local -a run_dirs=()
  local -a run_labels=()

  # Collect run-NNN-<branch> dirs under agent-teams/
  if [[ -d "${logs_root}/agent-teams" ]]; then
    for d in "${logs_root}/agent-teams"/run-*/; do
      [[ -d "$d" ]] || continue
      run_dirs+=("$d")
    done
    # Legacy: bare attempt-* dirs directly under agent-teams/
    for d in "${logs_root}/agent-teams"/attempt-*/; do
      [[ -d "$d" ]] || continue
      run_dirs+=("${logs_root}/agent-teams")
      break  # only add once for the legacy flat layout
    done
  fi

  # Collect claude-teams/ legacy logs
  if [[ -d "${logs_root}/claude-teams" ]]; then
    local ct_files=0
    for f in "${logs_root}/claude-teams"/*; do
      [[ -e "$f" ]] && ct_files=1 && break
    done
    if [[ $ct_files -eq 1 ]]; then
      run_dirs+=("${logs_root}/claude-teams")
    fi
  fi

  if [[ ${#run_dirs[@]} -eq 0 ]]; then
    ralph_log INFO "No session logs found."
    return 1
  fi

  echo ""
  echo "=== Ralph Session Logs ==="
  echo ""

  local idx=1
  for d in "${run_dirs[@]}"; do
    local label modified_at file_count
    label=$(_logs_run_label "$d")

    file_count=$(find "$d" -type f 2>/dev/null | wc -l | tr -d ' ')

    local newest=""
    newest=$(find "$d" -type f -print0 2>/dev/null | xargs -0 ls -t 2>/dev/null | head -1)
    if [[ -n "$newest" ]]; then
      if [[ "$(uname)" == "Darwin" ]]; then
        modified_at=$(stat -f "%Sm" -t "%Y-%m-%d %H:%M" "$newest" 2>/dev/null || echo "unknown")
      else
        modified_at=$(stat -c "%y" "$newest" 2>/dev/null | cut -d. -f1 || echo "unknown")
      fi
    else
      modified_at="empty"
    fi

    printf "  %3d) %-40s  %s files  (%s)\n" "$idx" "$label" "$file_count" "$modified_at"
    run_labels+=("$label")
    idx=$((idx + 1))
  done

  echo ""
  local count=${#run_dirs[@]}
  local selection
  printf "  Select a run [1-%d] (or 'q' to quit): " "$count"
  read -r selection </dev/tty

  if [[ "$selection" == "q" || "$selection" == "Q" || -z "$selection" ]]; then
    return 1
  fi

  if [[ "$selection" =~ ^[0-9]+$ ]] && [[ "$selection" -ge 1 ]] && [[ "$selection" -le "$count" ]]; then
    local chosen="${run_dirs[$((selection - 1))]}"
    _logs_browse_dir "$chosen" "$pager"
    return 0
  fi

  echo "  Invalid selection."
  return 0
}

_logs_run_label() {
  local dir="$1"
  local base
  base=$(basename "$dir")
  local parent
  parent=$(basename "$(dirname "$dir")")

  if [[ "$parent" == "agent-teams" && "$base" == run-* ]]; then
    echo "$base"
  elif [[ "$base" == "agent-teams" ]]; then
    echo "agent-teams (legacy flat)"
  elif [[ "$base" == "claude-teams" ]]; then
    echo "claude-teams (legacy)"
  else
    echo "$base"
  fi
}

_logs_browse_dir() {
  local dir="$1"
  local pager="$2"

  while true; do
    local -a items=()
    local -a item_paths=()

    # Collect subdirectories (attempt-N, etc.)
    for sub in "$dir"/*/; do
      [[ -d "$sub" ]] || continue
      items+=("$(basename "$sub")/")
      item_paths+=("$sub")
    done

    # Collect files
    for f in "$dir"/*; do
      [[ -f "$f" ]] || continue
      items+=("$(basename "$f")")
      item_paths+=("$f")
    done

    if [[ ${#items[@]} -eq 0 ]]; then
      echo "  (empty directory)"
      return
    fi

    echo ""
    echo "--- $(basename "$dir") ---"
    echo ""

    local idx=1
    for item in "${items[@]}"; do
      local path="${item_paths[$((idx - 1))]}"
      local size_info=""
      if [[ -f "$path" ]]; then
        local lines
        lines=$(wc -l < "$path" | tr -d ' ')
        size_info="${lines} lines"
      elif [[ -d "$path" ]]; then
        local fc
        fc=$(find "$path" -type f 2>/dev/null | wc -l | tr -d ' ')
        size_info="${fc} files"
      fi
      printf "  %3d) %-40s  (%s)\n" "$idx" "$item" "$size_info"
      idx=$((idx + 1))
    done

    echo ""
    local count=${#items[@]}
    printf "  Select [1-%d], 'b' to go back, 'q' to quit: " "$count"
    local sel
    read -r sel </dev/tty

    if [[ "$sel" == "q" || "$sel" == "Q" ]]; then
      exit 0
    fi
    if [[ "$sel" == "b" || "$sel" == "B" || -z "$sel" ]]; then
      return
    fi

    if [[ "$sel" =~ ^[0-9]+$ ]] && [[ "$sel" -ge 1 ]] && [[ "$sel" -le "$count" ]]; then
      local chosen="${item_paths[$((sel - 1))]}"
      if [[ -d "$chosen" ]]; then
        _logs_browse_dir "$chosen" "$pager"
      elif [[ -f "$chosen" ]]; then
        echo ""
        echo "=== $(basename "$chosen") ==="
        "$pager" "$chosen" </dev/tty
      fi
    else
      echo "  Invalid selection."
    fi
  done
}

cmd_prune() {
  local session_filter=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --session) session_filter="$2"; shift 2 ;;
      *) shift ;;
    esac
  done

  source "${RALPH_ROOT}/lib/worktree.sh"

  local sessions_dir="${RALPH_ROOT}/state/sessions"

  if [[ -n "$session_filter" ]]; then
    # Prune a single session
    local sdir="${sessions_dir}/${session_filter}"
    if [[ ! -d "$sdir" ]]; then
      ralph_die "Session not found: $session_filter"
    fi

    _prune_session "$sdir"
    ralph_log INFO "Session $session_filter pruned."
    return
  fi

  local state_dir="${RALPH_ROOT}/state"

  if [[ ! -d "$state_dir" ]]; then
    ralph_log INFO "Nothing to prune — state directory does not exist."
    return
  fi

  # Count sessions
  local session_count=0
  if [[ -d "$sessions_dir" ]]; then
    for d in "$sessions_dir"/*/; do
      [[ -d "$d" ]] && session_count=$((session_count + 1))
    done
  fi

  echo "This will permanently delete all Ralph state:"
  echo "  - Sessions      ($session_count session(s) with worktrees)"
  echo "  - Logs          (state/logs/)"
  echo "  - Prompts       (state/prompts/)"
  echo ""
  echo "  Tip: prune a single session with 'ralph prune --session <id>'"
  echo ""

  local confirm=""
  read -r -p "Are you sure? [y/N] " confirm </dev/tty
  if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
    ralph_log INFO "Prune cancelled."
    return
  fi

  # Remove worktrees for all sessions
  if [[ -d "$sessions_dir" ]]; then
    for sdir in "$sessions_dir"/*/; do
      [[ -d "$sdir" ]] || continue
      _prune_session "$sdir"
    done
  fi

  rm -rf "$state_dir"
  mkdir -p "$state_dir"/{logs,prompts}

  ralph_log INFO "State wiped. Ralph is back to factory fresh."
}

_prune_session() {
  local sdir="$1"
  local sid
  sid=$(basename "$sdir")

  if [[ -f "${sdir}/session.json" ]]; then
    local orig_repo wt_path
    orig_repo=$(jq -r '.original_target_repo // empty' "${sdir}/session.json")
    wt_path=$(jq -r '.worktree_path // empty' "${sdir}/session.json")

    if [[ -n "$orig_repo" ]] && [[ -n "$wt_path" ]]; then
      ralph_log INFO "  Removing worktree: $wt_path"
      worktree_remove "$orig_repo" "$wt_path"
    fi
  fi

  rm -rf "$sdir"
  ralph_log INFO "  Removed session state: $sid"
}

cmd_templates() {
  local template_dir="${RALPH_ROOT}/state/templates"
  local defaults_dir="${RALPH_ROOT}/templates"

  # Ensure user copies exist
  sync_templates "$RALPH_ROOT"

  local arg="${1:-}"

  # Handle --reset
  if [[ "$arg" == "--reset" ]]; then
    echo "This will overwrite all customized templates with the defaults."
    printf "Are you sure? [y/N] "
    local confirm
    read -r confirm </dev/tty
    if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
      reset_templates "$RALPH_ROOT"
      ralph_log INFO "All templates reset to defaults."
    else
      ralph_log INFO "Reset cancelled."
    fi
    return
  fi

  # Handle editing a specific template
  if [[ -n "$arg" ]]; then
    local target="${template_dir}/${arg}"
    if [[ ! -f "$target" ]]; then
      target="${template_dir}/${arg}.md"
    fi
    if [[ ! -f "$target" ]]; then
      ralph_die "Template not found: $arg (run 'ralph templates' to list all)"
    fi

    local editor="${EDITOR:-${VISUAL:-}}"
    if [[ -z "$editor" ]]; then
      command -v nano >/dev/null 2>&1 && editor="nano" || editor="vi"
    fi
    "$editor" "$target"
    return
  fi

  # List all templates
  echo ""
  echo "=== Ralph Prompt Templates ==="
  echo ""
  echo "  Editable copies in: ${template_dir}/"
  echo "  Defaults in:        ${defaults_dir}/"
  echo ""

  local idx=1
  for f in "$template_dir"/prompt-*.md; do
    [[ -f "$f" ]] || continue
    local name
    name=$(basename "$f")
    local desc=""
    case "$name" in
      prompt-team.md)              desc="Team orchestration prompt" ;;
      prompt-plan.md)              desc="Planning / task breakdown prompt" ;;
      prompt-manager-respond.md)   desc="Manager turn-by-turn response prompt" ;;
      prompt-verify.md)            desc="Completion verification prompt" ;;
      *)                           desc="" ;;
    esac

    # Show if user has modified the template
    local modified=""
    if [[ -f "${defaults_dir}/${name}" ]] && ! diff -q "${defaults_dir}/${name}" "$f" >/dev/null 2>&1; then
      modified=" (customized)"
    fi

    printf "  %2d) %-30s  %s%s\n" "$idx" "$name" "$desc" "$modified"
    idx=$((idx + 1))
  done

  echo ""
  echo "  Edit a template:    ralph templates prompt-team.md"
  echo "  Reset to defaults:  ralph templates --reset"
  echo ""
}

# Interactive AI tool picker. Prints the chosen tool name to stdout.
# Args: [current_tool] — shown as default; if empty, defaults to claude-code.
_pick_ai_tool() {
  local current="${1:-claude-code}"
  echo "" >&2
  echo "  Which AI tool will you use?" >&2
  echo "" >&2
  echo "    1) claude-code   (best supported, native Agent Teams)" >&2
  echo "    2) cursor         (Cursor CLI — agent)" >&2
  echo "    3) copilot        (GitHub Copilot CLI — copilot)" >&2
  echo "    4) generic        (any CLI tool)" >&2
  echo "" >&2
  printf "  Choice [current: %s]: " "$current" >&2
  local choice
  read -r choice </dev/tty
  case "${choice}" in
    1) echo "claude-code" ;;
    2) echo "cursor" ;;
    3) echo "copilot" ;;
    4) echo "generic" ;;
    *) echo "$current" ;;
  esac
}

# Build ai_tool_command from tool + model.
# Args: ai_tool model
_build_tool_command() {
  local tool="$1" model="$2"
  case "$tool" in
    claude-code) echo "claude --model ${model} -p" ;;
    cursor)      echo "agent --model ${model} -p" ;;
    copilot)     echo "copilot --allow-all --model ${model} -p" ;;
    generic)
      printf "  Enter the command to invoke your AI tool: " >&2
      local cmd
      read -r cmd </dev/tty
      [[ -z "$cmd" ]] && ralph_die "AI command is required for generic tools."
      echo "$cmd"
      ;;
  esac
}

# Interactive model picker. Prints the chosen model name to stdout.
# Args: ai_tool current_model
_pick_model() {
  local ai_tool="${1:-claude-code}" current="${2:-sonnet}"
  echo "" >&2
  echo "  Which model?" >&2
  echo "" >&2
  if [[ "$ai_tool" == "claude-code" ]]; then
    echo "    1) sonnet        (Claude Sonnet - fast, affordable)" >&2
    echo "    2) opus          (Claude Opus - smartest, expensive)" >&2
    echo "    3) haiku         (Claude Haiku - fastest, cheapest)" >&2
    echo "    4) gpt-4.1       (OpenAI GPT-4.1)" >&2
    echo "    5) gpt-4.1-mini  (OpenAI GPT-4.1 Mini)" >&2
    echo "    6) o3            (OpenAI o3)" >&2
    echo "    7) gemini-2.5    (Google Gemini 2.5 Pro)" >&2
    echo "    8) Custom        (type your own)" >&2
  else
    echo "    1) sonnet        (Claude Sonnet)" >&2
    echo "    2) opus          (Claude Opus)" >&2
    echo "    3) gpt-4.1       (OpenAI GPT-4.1)" >&2
    echo "    4) gpt-4.1-mini  (OpenAI GPT-4.1 Mini)" >&2
    echo "    5) o3            (OpenAI o3)" >&2
    echo "    6) gemini-2.5    (Google Gemini 2.5 Pro)" >&2
    echo "    7) Custom        (type your own)" >&2
  fi
  echo "" >&2
  printf "  Model [current: %s]: " "$current" >&2
  local choice
  read -r choice </dev/tty
  if [[ "$ai_tool" == "claude-code" ]]; then
    case "${choice}" in
      1) echo "sonnet" ;; 2) echo "opus" ;; 3) echo "haiku" ;;
      4) echo "gpt-4.1" ;; 5) echo "gpt-4.1-mini" ;; 6) echo "o3" ;;
      7) echo "gemini-2.5-pro" ;;
      8) printf "\n  Model name: " >&2; local m; read -r m </dev/tty; echo "${m:-$current}" ;;
      "") echo "$current" ;; *) echo "$current" ;;
    esac
  else
    case "${choice}" in
      1) echo "sonnet" ;; 2) echo "opus" ;;
      3) echo "gpt-4.1" ;; 4) echo "gpt-4.1-mini" ;; 5) echo "o3" ;;
      6) echo "gemini-2.5-pro" ;;
      7) printf "\n  Model name: " >&2; local m; read -r m </dev/tty; echo "${m:-$current}" ;;
      "") echo "$current" ;; *) echo "$current" ;;
    esac
  fi
}

cmd_agent() {
  local config_file="$1"; shift
  local subcmd="${1:-switch}"

  if [[ "$subcmd" != "switch" ]]; then
    ralph_die "Unknown subcommand: ralph agent $subcmd (available: switch)"
  fi

  require_jq

  local current_tool current_model current_mgr_model
  current_tool=$(config_get "$config_file" '.ai_tool' 'claude-code')
  current_model=$(config_get "$config_file" '.model' 'sonnet')
  current_mgr_model=$(config_get "$config_file" '.manager_model' 'sonnet')

  echo ""
  echo "=== Switch AI Agent ==="
  echo ""
  echo "  Current CLI:            $current_tool"
  echo "  Current model:          $current_model"
  echo "  Current manager model:  $current_mgr_model"
  echo ""

  local ai_tool
  ai_tool=$(_pick_ai_tool "$current_tool")
  echo ""

  local model="$current_model"
  local mgr_model="$current_mgr_model"

  if [[ "$ai_tool" != "$current_tool" ]]; then
    echo "  Switched CLI to: $ai_tool"
    echo ""
  else
    echo "  Keeping CLI: $ai_tool"
    echo ""
  fi

  printf "  Switch models too? [y/N]: "
  read -r switch_models </dev/tty
  echo ""

  if [[ "$switch_models" == "y" || "$switch_models" == "Y" ]]; then
    model=$(_pick_model "$ai_tool" "$current_model")
    echo ""

    printf "  Manager model [current: %s, enter = same as worker]: " "$current_mgr_model"
    read -r mgr_choice </dev/tty
    if [[ -z "$mgr_choice" ]]; then
      mgr_model="$model"
    else
      mgr_model="$mgr_choice"
    fi
    echo ""
  fi

  local ai_tool_command
  ai_tool_command=$(_build_tool_command "$ai_tool" "$model")

  # Handle allow_all for copilot
  local allow_all
  allow_all=$(config_get "$config_file" '.allow_all' 'false')
  if [[ "$ai_tool" == "copilot" ]]; then
    allow_all="true"
  fi

  # Update config
  local tmp="${config_file}.tmp.$$"
  jq \
    --arg tool "$ai_tool" \
    --arg cmd "$ai_tool_command" \
    --arg m "$model" \
    --arg mm "$mgr_model" \
    --argjson aa "$allow_all" \
    '.ai_tool = $tool | .ai_tool_command = $cmd | .model = $m | .manager_model = $mm | .allow_all = $aa' \
    "$config_file" > "$tmp" && mv "$tmp" "$config_file"

  echo "  Updated ralph.config.json:"
  echo ""
  echo "    ai_tool:          $ai_tool"
  echo "    ai_tool_command:  $ai_tool_command"
  echo "    model:            $model"
  echo "    manager_model:    $mgr_model"
  echo ""
  ralph_log INFO "Agent switch complete. Changes take effect on the next 'ralph start'."
}

cmd_settings() {
  local config_file="$1"

  if [[ ! -f "$config_file" ]]; then
    ralph_log WARN "No config found. Run 'ralph init' first, or creating from example..."
    if [[ -f "${RALPH_ROOT}/ralph.config.example.json" ]]; then
      cp "${RALPH_ROOT}/ralph.config.example.json" "$config_file"
    else
      ralph_die "No config and no example file found. Run 'ralph init' to set up."
    fi
  fi

  # Pick an editor: $EDITOR > $VISUAL > nano > vi
  local editor="${EDITOR:-${VISUAL:-}}"
  if [[ -z "$editor" ]]; then
    if command -v nano >/dev/null 2>&1; then
      editor="nano"
    elif command -v vi >/dev/null 2>&1; then
      editor="vi"
    else
      ralph_die "No editor found. Set \$EDITOR or install nano."
    fi
  fi

  ralph_log INFO "Opening $config_file with $editor"
  "$editor" "$config_file"

  # Validate JSON after editing
  if command -v jq >/dev/null 2>&1; then
    if jq empty "$config_file" 2>/dev/null; then
      ralph_log INFO "Config saved. JSON is valid."
    else
      ralph_log WARN "Warning: $config_file is not valid JSON. You may want to fix it."
      ralph_log WARN "Run 'ralph settings' again to edit."
    fi
  fi
}

cmd_plan() {
  local config="$1"; shift
  local prompt_input="${1:-}"

  local prompt_file
  prompt_file=$(resolve_prompt "$prompt_input" "$config") || \
    ralph_die "Prompt required for planning. Use -p \"your prompt\" or -p file.md"

  local target_repo
  target_repo=$(config_get "$config" '.default_target_repo' '')
  if [[ -z "$target_repo" ]]; then
    target_repo=$(config_get "$config" '.target_repo' '.')
  fi

  ralph_log INFO "Running Ralph in planning mode..."
  
  source "${RALPH_ROOT}/lib/loop-engine.sh"

  # Use planning prompt template
  local plan_prompt="${RALPH_ROOT}/state/prompts/.ralph-plan-prompt.md"
  mkdir -p "${RALPH_ROOT}/state/prompts"
  sync_templates "$RALPH_ROOT"
  local template="${RALPH_ROOT}/state/templates/prompt-plan.md"
  
  if [[ -f "$template" ]]; then
    render_template "$template" \
      PROMPT_FILE "$prompt_file" \
      TARGET_REPO "$target_repo" > "$plan_prompt"
  else
    cp "$prompt_file" "$plan_prompt"
  fi

  ralph_loop "$config" "$plan_prompt" "plan-$(generate_id)"
}

main "$@"
