{
  "version": "1.0.0",
  "default_target_repo": ".",
  "prompt_text": "",
  "ai_tool": "claude-code",
  "ai_tool_command": "claude -p",
  "model": "sonnet",
  "manager_model": "sonnet",
  "allow_all": false,
  "turns": 50,
  "_model_options": ["sonnet", "opus", "haiku", "gpt-4.1", "gpt-4.1-mini", "o3", "gemini-2.5-pro"],
  "team": {
    "implementers": 3,
    "reviewers": 2
  },
  "loop": {
    "max_iterations": 3,
    "completion_promise": "ALL_TASKS_COMPLETE"
  },
  "claude_teams": {
    "teammate_mode": "in-process"
  }
}
